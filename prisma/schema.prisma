generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  service   String
  budget    String?
  message   String
  status    String   @default("novo")
  source    String   @default("site")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model ChatConversation {
  id        String   @id @default(cuid())
  visitorId String
  visitorName String?
  visitorEmail String?
  status    String   @default("active") // active, waiting_human, resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]

  @@index([visitorId])
  @@index([status])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // visitor, ai, human
  content        String
  adminName      String?
  createdAt      DateTime @default(now())

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}

model ChatSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("chat_settings")
}

model ChatPrompt {
  id        String   @id @default(cuid())
  name      String
  content   String
  category  String   @default("atendimento")
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chat_prompts")
}
